# --- Backend (server-side, NEVER expose to the browser) -------------------
# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key — full access, bypasses RLS. Server-only secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Client (Vite, exposed to the browser — safe, anon key only) ----------
# Same project URL as above (public).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Public anon key — safe to ship to the browser; RLS protects the data.
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: override the API base the client talks to (defaults to same origin).
# VITE_API_BASE=
